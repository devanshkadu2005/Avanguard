# Copy this to .env and fill in your values
# DO NOT commit .env — it is gitignored

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

# Pipeline behaviour: "closed" blocks on failure, "open" passes with WARNING
FAIL_MODE=closed

# JWT secret — must be at least 32 characters
JWT_SECRET=change-me-to-a-long-random-secret-string

# NVIDIA API key for LLM
NVIDIA_API_KEY=nvapi-...

# Admin credentials (initial seed — change after first deploy)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Comma-separated list of allowed frontend origins (optional, Vercel URLs auto-allowed)
ALLOWED_ORIGINS=https://your-app.vercel.app
